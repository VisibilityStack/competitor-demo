---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/fpt-dice.css';
import ChatWidget from '../components/ChatWidget.astro';
import DxMotion from '../components/DxMotion.astro';

const { title, updated = 'July 2026' } = Astro.props;
const canonical = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/', 'https://www.fptalent.io').href;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());
			gtag('config', 'G-XN05QF08LJ');
			addEventListener(
				'load',
				() => {
					const s = document.createElement('script');
					s.async = true;
					s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XN05QF08LJ';
					document.head.appendChild(s);
				},
				{ once: true }
			);
		</script>
		<title>{title} · FP Talent</title>
		<meta name="description" content={`${title} for fptalent.io`} />
		<link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg?v=2" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png?v=2" />
		<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png?v=2" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="FP Talent" />
		<meta property="og:title" content={`${title} · FP Talent`} />
		<meta property="og:description" content={`${title} for fptalent.io`} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content="https://www.fptalent.io/social.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="preload" href="/assets/fonts/ibm-plex-sans-latin-var.woff2" as="font" type="font/woff2" crossorigin />
	</head>
	<body>
		<a class="dx-skip" href="#main">Skip to content</a>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo badge" href="/">FPT</a>
				<div class="dx-nav-links">
					<a href="/candidates/#searches">Open searches</a>
					<a href="/#practices">Practices</a>
					<a href="/insights/">Insights</a>
					<a href="/#why">Why FPT</a>
				</div>
				<details class="dx-nav-mob">
				<summary aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></summary>
				<div class="dx-nav-mob-panel">
						<a href="/candidates/#searches">Open searches</a>
						<a href="/#practices">Practices</a>
						<a href="/insights/">Insights</a>
						<a href="/#why">Why FPT</a>
						<a href="/candidates/">For candidates</a>
					</div>
			</details>
			<div class="dx-nav-right">
					<a class="dx-btn ghost" href="/candidates/">For candidates</a>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main class="dx-article-page" id="main">
			<div class="dx-container dx-article-layout">
				<article class="dx-article-main">
					<p class="dx-legal-updated" data-dxa>Last updated: {updated}</p>
					<h1 data-dxa>{title}</h1>
					<div class="dx-prose">
						<slot />
					</div>
				</article>

				<aside class="dx-side">
					<div class="dx-side-card" data-dxa>
						<h2>Legal</h2>
						<a class="dx-side-item" href="/terms/"><span class="t">Terms of Use</span></a>
						<a class="dx-side-item" href="/privacy/"><span class="t">Privacy Policy</span></a>
						<a class="dx-side-all" href="/">Back to the site →</a>
					</div>
					<div class="dx-side-cta slim" data-dxa>
						<h2>Questions?</h2>
						<a class="dx-btn teal" href="mailto:mark@fptalent.io?subject=Question%20about%20your%20terms">Email us</a>
					</div>
				</aside>
			</div>
		</main>

		<footer class="dx-subfooter">
			<div class="dx-container dx-legal">
				<span>© 2026 FP Talent. All rights reserved.</span>
				<span>
					<a href="/terms/">Terms</a>
					<a href="/privacy/">Privacy policy</a>
				</span>
			</div>
		</footer>
		<DxMotion />
		<ChatWidget />
		<Analytics />
		<SpeedInsights />
	</body>
</html>
