---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/fpt-dice.css';
import ChatWidget from '../components/ChatWidget.astro';

const { title, updated = 'July 2026' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} . FP Talent</title>
		<meta name="description" content={`${title} for fptalent.io`} />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
		/>
		<Analytics />
		<SpeedInsights />
	</head>
	<body>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo" href="/">FPT<span class="dx-logo-block"></span></a>
				<div class="dx-nav-links">
					<a href="/candidates#searches">Open searches</a>
					<a href="/#practices">Practices</a>
					<a href="/insights">Insights</a>
					<a href="/#why">Why FPT</a>
				</div>
				<div class="dx-nav-right">
					<a class="quiet" href="/candidates">For candidates</a>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main class="dx-legal-main">
			<p class="dx-legal-updated">Last updated: {updated}</p>
			<h1>{title}</h1>
			<slot />
		</main>

		<footer class="dx-subfooter">
			<div class="dx-container dx-legal">
				<span>© 2026 FP Talent. All rights reserved.</span>
				<span>
					<a href="/terms">Terms</a>
					<a href="/privacy">Privacy policy</a>
				</span>
			</div>
		</footer>
		<ChatWidget />
	</body>
</html>
