---
import '../styles/fpt.css';
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>404 . FP Talent</title>
		<meta name="robots" content="noindex" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=News+Cycle:wght@400;700&display=swap"
		/>
		<style>
			.nf {
				min-height: 100svh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 10px;
				background: #111;
				color: #fff;
				text-align: center;
				padding: 24px;
			}
			.nf-code {
				font-size: clamp(100px, 22vw, 280px);
			}
			.nf-code .dot {
				color: #e02020;
			}
			.nf-line {
				font-family: var(--font-display);
				font-size: clamp(20px, 3vw, 34px);
				letter-spacing: 0.16em;
				text-transform: uppercase;
			}
			.nf a {
				margin-top: 26px;
				font-family: var(--font-display);
				font-size: 18px;
				letter-spacing: 0.12em;
				background: #e02020;
				color: #fff;
				padding: 12px 20px 10px;
				text-transform: uppercase;
			}
		</style>
	</head>
	<body>
		<div class="nf">
			<h1 class="display nf-code">404<span class="dot">.</span></h1>
			<p class="nf-line">Nothing ships here.</p>
			<a href="/">Back to the homepage</a>
		</div>
	</body>
</html>
