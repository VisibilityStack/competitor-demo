---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../../styles/fpt-dice.css';
import ChatWidget from '../../components/ChatWidget.astro';
import DxMotion from '../../components/DxMotion.astro';

export function getStaticPaths() {
	const practices = [
		{
			slug: 'product',
			name: 'Product',
			metaTitle: 'Hire Product Managers',
			intent: 'Hire product managers who ship.',
			intro:
				'From your first PM to a full product org, we place product people who turn roadmaps into releases. Screened for real fit.',
			roles: ['Product Managers', 'Senior PMs', 'Group PMs', 'Founding PMs', 'Product Ops'],
			why: [
				{
					t: 'First-PM specialists',
					c: 'The hardest product hire is the first one. We scope the role against your stage, not a template JD.',
				},
				{
					t: 'Fit is measured',
					c: 'Psychometric and culture mapping on every shortlist, included free. Product sense is tested, not assumed.',
				},
				{
					t: 'Founder-speed',
					c: 'You meet a screened shortlist in days. The −29% time-to-hire stat is the system working.',
				},
			],
			faqs: [
				{
					q: 'Can you find our first product manager?',
					a: 'Yes, first-PM searches are our specialty. We help you decide what the role even is before we search: builder PM, growth PM, or a head of product in waiting.',
				},
				{
					q: 'Do you place fractional or full-time PMs?',
					a: 'Full-time placements are our core. For interim needs we can scope the search for a contract-to-hire arrangement.',
				},
				{
					q: 'How do you test product sense?',
					a: 'Structured case rounds with your stakeholders plus psychometric screening. Candidates reach you only after clearing both.',
				},
			],
			cta: "Let's build your product team.",
		},
		{
			slug: 'engineering',
			name: 'Engineering',
			metaTitle: 'Hire Software Engineers',
			intent: 'Hire engineers who ship.',
			intro:
				'Full-stack, backend, and frontend engineers for software companies that measure output in releases. Sourced from our network, screened to a shortlist worth your calendar.',
			roles: ['Full-Stack Engineers', 'Backend Engineers', 'Frontend Engineers', 'Founding Engineers', 'DevOps & Platform'],
			why: [
				{
					t: 'People who ship',
					c: 'We look for engineers with shipped products behind them, and we reach them directly.',
				},
				{
					t: 'Panels that respect engineers',
					c: 'Technical rounds designed with your stakeholders. High signal, no whiteboard hazing.',
				},
				{
					t: 'Retention built in',
					c: 'Culture mapping on every candidate. 82% of the people we place are still in seat at 12 months because fit is the whole system.',
				},
			],
			faqs: [
				{
					q: 'Which stacks do you cover?',
					a: 'The modern web and cloud mainstream: TypeScript, Python, Go, React, Node, and the infrastructure around them. If your stack is unusual, we tell you up front whether we can search it well.',
				},
				{
					q: 'Do you place founding engineers?',
					a: 'Yes. Founding-engineer searches get the same treatment as leadership searches: equity-literate candidates, stage-fit screening, and founder references.',
				},
				{
					q: 'How technical is your screening?',
					a: 'We run structured technical interviews before you ever see a candidate, then coordinate your own panel rounds. You interview three great people instead of thirty resumes.',
				},
			],
			cta: "Let's build your engineering team.",
		},
		{
			slug: 'data-ai',
			name: 'Data & AI',
			metaTitle: 'Hire Data Scientists & AI Engineers',
			intent: 'Hire data and AI people who ship.',
			intro:
				'Data scientists and ML engineers who get models into production, not just notebooks. Screened for engineering rigor as much as research depth.',
			roles: ['Data Scientists', 'ML Engineers', 'AI Engineers', 'Analytics Engineers', 'Data Platform'],
			why: [
				{
					t: 'Production over papers',
					c: 'We screen for shipped ML systems and data products, not citation counts.',
				},
				{
					t: 'Rare-skill sourcing',
					c: 'The best data and AI people are never on job boards. Our network search finds the ones quietly shipping.',
				},
				{
					t: 'Stage-fit screening',
					c: 'A seed-stage data hire and an enterprise one are different jobs. We scope which one you actually need.',
				},
			],
			faqs: [
				{
					q: 'Can you hire for applied AI product roles?',
					a: 'Yes, including AI engineers building on foundation models, retrieval systems, and agentic products, where engineering judgment matters more than research pedigree.',
				},
				{
					q: 'Do candidates get technical screening?',
					a: 'Every shortlist has passed structured technical rounds plus psychometric screening before you meet them.',
				},
				{
					q: 'We are not sure if we need a data scientist or an ML engineer. Can you help?',
					a: 'That is exactly what the discovery call and JD co-writing step solve. We scope the role from your actual problems before searching.',
				},
			],
			cta: "Let's build your data team.",
		},
		{
			slug: 'leadership',
			name: 'Leadership',
			metaTitle: 'CTO, CPO & Engineering Leadership Search',
			intent: 'Hire leaders who raise the bar.',
			intro:
				'CPOs, VPs of Engineering, CTOs, and Heads of Data for companies where the next leader changes the trajectory.',
			roles: ['CTOs', 'VPs of Engineering', 'CPOs', 'Heads of Product', 'Heads of Data & AI'],
			why: [
				{
					t: 'The senior layer is our strength',
					c: 'Senior searches are most of what we run, and the ones we screen hardest. Leaders set the bar for everyone under them.',
				},
				{
					t: 'Confidential by default',
					c: 'Leadership searches run discreetly, on both sides. References and track records are verified before shortlists.',
				},
				{
					t: 'Stakeholder-aligned panels',
					c: 'We design the interview panel with your board or founders so the decision holds after the hire.',
				},
			],
			faqs: [
				{
					q: 'Do you run confidential replacement searches?',
					a: 'Yes. Confidential searches are common at the leadership level and we run them with strict discretion on both sides.',
				},
				{
					q: 'How long does a leadership search take?',
					a: 'Meaningfully faster than a classic retained firm. You meet a screened shortlist in weeks, not quarters, without skipping references or psychometrics.',
				},
				{
					q: 'Can you assess leaders for a specific stage transition?',
					a: 'Yes. Scaling from 10 to 50 engineers is a different job than 100 to 500. Stage fit is a core screening dimension in every leadership search.',
				},
			],
			cta: "Let's find your next leader.",
		},
	];
	return practices.map(p => ({ params: { slug: p.slug }, props: { p } }));
}

const { p } = Astro.props;

const steps = [
	{ no: '01', t: 'JD co-writing', c: 'We co-write the JD until it describes the person you actually need.' },
	{ no: '02', t: 'Sourcing', c: 'We reach out directly to proven people in our network and beyond, instead of waiting for applications.' },
	{ no: '03', t: 'Psychometric screen', c: 'Tests and culture mapping, included free. Fit is measured, not guessed.' },
	{ no: '04', t: 'Panels', c: 'Technical and cultural rounds with your stakeholders. High signal only.' },
	{ no: '05', t: 'Signed offer', c: 'We handle the offer and the close. You get a signed acceptance and a start date.' },
];

const stats = [
	{ count: 29, prefix: '−', suffix: '%', v: '−29%', c: 'time-to-hire on mid to senior roles' },
	{ count: 82, suffix: '%', v: '82%', c: 'of placed candidates still in seat at 12 months' },
	{ count: 9, suffix: ' days', v: '9 days', c: 'median from first call to first founder interview' },
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: p.faqs.map(f => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
};
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{p.metaTitle} · FP Talent</title>
		<meta name="description" content={`${p.intent} ${p.intro}`} />
		<link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg?v=2" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
		<link rel="canonical" href={`https://www.fptalent.io/practices/${p.slug}`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<Analytics />
		<SpeedInsights />
	</head>
	<body>
		<a class="dx-skip" href="#main">Skip to content</a>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo badge" href="/">FPT</a>
				<div class="dx-nav-links">
					<a href="/candidates#searches">Open searches</a>
					<a href="/#practices">Practices</a>
					<a href="/insights">Insights</a>
					<a href="/#why">Why FPT</a>
				</div>
				<details class="dx-nav-mob">
				<summary aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></summary>
				<div class="dx-nav-mob-panel">
						<a href="/candidates#searches">Open searches</a>
						<a href="/#practices">Practices</a>
						<a href="/insights">Insights</a>
						<a href="/#why">Why FPT</a>
						<a href="/candidates">For candidates</a>
					</div>
			</details>
			<div class="dx-nav-right">
					<a class="dx-btn ghost" href="/candidates">For candidates</a>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main id="main">
		<header class="dxc-hero dxp-hero">
			<div class="dx-container">
				<p class="dxp-kicker" data-dxa>{p.name} practice</p>
				<h1 data-dxa>{p.intent.replace(/\.$/, '')}<span class="accent">.</span></h1>
				<p class="dxc-sub" data-dxa>{p.intro}</p>
				<div class="dx-cta-row" data-dxa>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
					<a class="dx-btn outline-light" href="#process">See how the search runs</a>
				</div>
			</div>
		</header>

		<section class="dx-sec">
			<div class="dx-container">
				<h2 class="dx-sec-head" data-dxa>Roles we place</h2>
				<div class="dx-cats" data-dxa>
					{p.roles.map(r => <span class="dx-cat">{r}</span>)}
				</div>
			</div>
		</section>

		<section id="process" class="dx-sec grey">
			<div class="dx-container">
				<h2 class="dx-sec-head" data-dxa>How the search runs</h2>
				<div class="dx-steps five">
					{
						steps.map(s => (
							<div data-dxa>
								<div class="dx-step">
									<div class="no">{s.no}</div>
									<div class="t">{s.t}</div>
									<div class="c">{s.c}</div>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-sec">
			<div class="dx-container">
				<h2 class="dx-sec-head" data-dxa>Why FPT</h2>
				<div class="dx-steps">
					{
						p.why.map(w => (
							<div data-dxa>
								<div class="dx-step">
									<div class="t">{w.t}</div>
									<div class="c">{w.c}</div>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-numbers" aria-label="Results across searches">
			<div class="dx-container">
				<div class="dx-tiles">
					{
						stats.map(s => (
							<div class="dx-tile" data-dxa>
								<span class="v" data-count={s.count} data-prefix={s.prefix} data-suffix={s.suffix}>
									{s.v}
								</span>
								<span class="c">{s.c}</span>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-sec grey">
			<div class="dx-container dx-faq-grid">
				<div class="dx-faq-intro" data-dxa>
					<h2 class="dx-sec-head">Questions founders ask</h2>
					<p class="dx-sec-sub">The three we hear most, answered straight.</p>
				</div>
				<div class="dx-faq">
					{
						p.faqs.map((f, i) => (
							<details class="dx-faq-item" data-dxa open={i === 0}>
								<summary>{f.q}</summary>
								<p>{f.a}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-sec">
			<div class="dx-container">
				<div class="dx-cta-card slim" data-dxa>
					<div>
						<h2>{p.cta}</h2>
						<p>A short call is enough to scope the search.</p>
					</div>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</section>

		</main>

		<footer class="dx-subfooter">
			<div class="dx-container dx-legal">
				<span>© 2026 FP Talent. All rights reserved.</span>
				<span>
					<a href="/terms">Terms</a>
					<a href="/privacy">Privacy policy</a>
				</span>
			</div>
		</footer>

		<DxMotion />
		<ChatWidget />
	</body>
</html>
