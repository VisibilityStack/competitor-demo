---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../../styles/fpt-dice.css';
import ChatWidget from '../../components/ChatWidget.astro';
import DxMotion from '../../components/DxMotion.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('insights');
	return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const all = (await getCollection('insights')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const sameCat = all.filter(
	x => x.slug !== post.slug && x.data.category === post.data.category
);
const others = all.filter(
	x => x.slug !== post.slug && x.data.category !== post.data.category
);
const related = [...sameCat, ...others].slice(0, 4);

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: post.data.title,
	description: post.data.description,
	datePublished: post.data.date.toISOString().slice(0, 10),
	author: { '@type': 'Organization', name: 'FP Talent', url: 'https://www.fptalent.io' },
	publisher: { '@type': 'Organization', name: 'FP Talent', url: 'https://www.fptalent.io' },
	mainEntityOfPage: `https://www.fptalent.io/insights/${post.slug}`,
};
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{post.data.title} · FP Talent</title>
		<meta name="description" content={post.data.description} />
		<link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg?v=2" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
		<link rel="canonical" href={`https://www.fptalent.io/insights/${post.slug}`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<Analytics />
		<SpeedInsights />
	</head>
	<body>
		<a class="dx-skip" href="#main">Skip to content</a>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo badge" href="/">FPT</a>
				<div class="dx-nav-links">
					<a href="/candidates#searches">Open searches</a>
					<a href="/#practices">Practices</a>
					<a href="/insights">Insights</a>
					<a href="/#why">Why FPT</a>
				</div>
				<details class="dx-nav-mob">
				<summary aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></summary>
				<div class="dx-nav-mob-panel">
						<a href="/candidates#searches">Open searches</a>
						<a href="/#practices">Practices</a>
						<a href="/insights">Insights</a>
						<a href="/#why">Why FPT</a>
						<a href="/candidates">For candidates</a>
					</div>
			</details>
			<div class="dx-nav-right">
					<a class="dx-btn ghost" href="/candidates">For candidates</a>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main class="dx-article-page" id="main">
			<div class="dx-container dx-article-layout">
				<article class="dx-article-main">
					<p class="dx-article-meta" data-dxa>
						<a class="crumb" href="/insights">Insights</a> · {post.data.category} ·
						{fmtDate(post.data.date)} · {post.data.readingTime}
					</p>
					<h1 data-dxa>{post.data.title}</h1>
					<div class="dx-prose">
						<Content />
					</div>
				</article>

				<aside class="dx-side">
					<div class="dx-side-card" data-dxa>
						<h3>More from Insights</h3>
						{
							related.map(r => (
								<a class="dx-side-item" href={`/insights/${r.slug}`}>
									<span class="cat">{r.data.category}</span>
									<span class="t">{r.data.title}</span>
								</a>
							))
						}
						<a class="dx-side-all" href="/insights">All articles →</a>
					</div>
					<div class="dx-side-cta" data-dxa>
						<h3>Let's build your team.</h3>
						<p>A short call is enough to scope the search.</p>
						<a class="dx-btn teal" href="/#contact">Book a consultation</a>
					</div>
				</aside>
			</div>
		</main>

		<footer class="dx-subfooter">
			<div class="dx-container dx-legal">
				<span>© 2026 FP Talent. All rights reserved.</span>
				<span>
					<a href="/terms">Terms</a>
					<a href="/privacy">Privacy policy</a>
				</span>
			</div>
		</footer>

		<DxMotion />
		<ChatWidget />
	</body>
</html>
