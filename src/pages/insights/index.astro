---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../../styles/fpt-dice.css';
import ChatWidget from '../../components/ChatWidget.astro';
import DxMotion from '../../components/DxMotion.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('insights')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const categories = [...new Set(posts.map(p => p.data.category))].map(cat => ({
	name: cat,
	count: posts.filter(p => p.data.category === cat).length,
}));

const faqs = [
	{
		q: 'What does a search cost?',
		a: 'A success fee when we place someone. No retainers, no add-ons.',
		href: '/insights/recruiting-fee-structures/',
		linkLabel: 'How agencies price searches.',
	},
	{
		q: 'How fast is a typical search?',
		a: '9 days median from first call to first founder interview, about 29% faster than the public benchmarks.',
		href: '/insights/time-to-hire-benchmarks/',
		linkLabel: 'The benchmarks.',
	},
	{
		q: 'Do the placements stick?',
		a: '82% of the people we place are still in seat at 12 months. Psychometric screening does the heavy lifting.',
		href: '/insights/psychometric-screening-mis-hires/',
		linkLabel: 'Why screening works.',
	},
];

const hubSchema = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Blog',
			'@id': 'https://www.fptalent.io/insights/#blog',
			name: 'FP Talent Insights',
			description:
				'Hiring insights from FP Talent: technical recruiting, psychometric screening, and building software teams that last.',
			url: 'https://www.fptalent.io/insights/',
			publisher: {
				'@type': 'Organization',
				name: 'FP Talent',
				url: 'https://www.fptalent.io',
				logo: { '@type': 'ImageObject', url: 'https://www.fptalent.io/favicon-512.png' },
			},
		},
		{
			'@type': 'ItemList',
			itemListElement: posts.map((p, i) => ({
				'@type': 'ListItem',
				position: i + 1,
				name: p.data.title,
				url: `https://www.fptalent.io/insights/${p.slug}/`,
			})),
		},
		{
			'@type': 'BreadcrumbList',
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.fptalent.io/' },
				{ '@type': 'ListItem', position: 2, name: 'Insights' },
			],
		},
		{
			'@type': 'FAQPage',
			mainEntity: faqs.map(f => ({
				'@type': 'Question',
				name: f.q,
				acceptedAnswer: { '@type': 'Answer', text: f.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());
			gtag('config', 'G-XN05QF08LJ');
			addEventListener(
				'load',
				() => {
					const s = document.createElement('script');
					s.async = true;
					s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XN05QF08LJ';
					document.head.appendChild(s);
				},
				{ once: true }
			);
		</script>
		<title>Technical Hiring & Recruiting Insights · FP Talent</title>
		<meta
			name="description"
			content="Hiring insights from FP Talent: technical recruiting, psychometric screening, and building software teams that last."
		/>
		<link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg?v=2" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png?v=2" />
		<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png?v=2" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
		<link rel="canonical" href="https://www.fptalent.io/insights/" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="FP Talent" />
		<meta property="og:title" content="Technical Hiring & Recruiting Insights · FP Talent" />
		<meta property="og:description" content="Hiring insights from FP Talent: technical recruiting, psychometric screening, and building software teams that last." />
		<meta property="og:url" content="https://www.fptalent.io/insights/" />
		<meta property="og:image" content="https://www.fptalent.io/social.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<script type="application/ld+json" set:html={JSON.stringify(hubSchema)} />
		<link rel="preload" href="/assets/fonts/ibm-plex-sans-latin-var.woff2" as="font" type="font/woff2" crossorigin />
	</head>
	<body>
		<a class="dx-skip" href="#main">Skip to content</a>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo badge" href="/">FPT</a>
				<div class="dx-nav-links">
					<a href="/candidates/#searches">Open searches</a>
					<a href="/#practices">Practices</a>
					<a href="/insights/">Insights</a>
					<a href="/#why">Why FPT</a>
				</div>
				<details class="dx-nav-mob">
				<summary aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></summary>
				<div class="dx-nav-mob-panel">
						<a href="/candidates/#searches">Open searches</a>
						<a href="/#practices">Practices</a>
						<a href="/insights/">Insights</a>
						<a href="/#why">Why FPT</a>
						<a href="/candidates/">For candidates</a>
					</div>
			</details>
			<div class="dx-nav-right">
					<a class="dx-btn ghost" href="/candidates/">For candidates</a>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main id="main">
		<header class="dx-hub-hero">
			<div class="dx-container">
				<h1 data-dxa>Hiring insights, <span class="accent">straight answers.</span></h1>
				<p data-dxa>
					How we think about technical hiring: screening, searches, fees, and
					building software teams that last.
				</p>
			</div>
		</header>

		<section class="dx-sec tight">
			<div class="dx-container">
				<h2 class="dx-sec-head" data-dxa>Browse the library</h2>
				<p class="dx-sec-sub" data-dxa>
					{posts.length} articles across {categories.length} categories. Filter by what you're hiring for.
				</p>
				<div class="dx-cats" aria-label="Filter by category" data-dxa>
					<button class="dx-cat active" data-cat="all">
						All <span class="dx-cat-count">{posts.length}</span>
					</button>
					{
						categories.map(c => (
							<button class="dx-cat" data-cat={c.name}>
								{c.name} <span class="dx-cat-count">{c.count}</span>
							</button>
						))
					}
				</div>

				<div class="dx-hub-grid" id="insight-list">
					{
						posts.map(post => (
							<div data-dxa data-category={post.data.category}>
								<a class="dx-article" href={`/insights/${post.slug}/`}>
									<span class="cat">{post.data.category}</span>
									<span class="t">{post.data.title}</span>
									<span class="desc">{post.data.description}</span>
									<span class="d">
										{fmtDate(post.data.date)} · {post.data.readingTime}
									</span>
								</a>
							</div>
						))
					}
				</div>

				<nav class="dx-pagination" id="pagination" aria-label="Pages"></nav>
			</div>
		</section>

		<section class="dx-sec flush">
			<div class="dx-container dx-faq-grid">
				<div class="dx-faq-intro" data-dxa>
					<h2 class="dx-sec-head">Quick answers</h2>
					<p class="dx-sec-sub">The three numbers founders ask about first.</p>
				</div>
				<div class="dx-faq">
					{
						faqs.map((f, i) => (
							<details class="dx-faq-item" data-dxa open={i === 0}>
								<summary>{f.q}</summary>
								<p>
									{f.a} <a class="dx-inline-link" href={f.href}>{f.linkLabel}</a>
								</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-sec flush">
			<div class="dx-container">
				<div class="dx-cta-card slim" data-dxa>
					<div>
						<h2>Let's build your team.</h2>
						<p>A short call is enough to scope the search.</p>
					</div>
					<a class="dx-btn teal" href="/#contact">Book a consultation</a>
				</div>
			</div>
		</section>

		</main>

		<footer class="dx-subfooter">
			<div class="dx-container dx-legal">
				<span>© 2026 FP Talent. All rights reserved.</span>
				<span>
					<a href="/terms/">Terms</a>
					<a href="/privacy/">Privacy policy</a>
				</span>
			</div>
		</footer>

		<script>
			// ---------- category filter + pagination ----------
			const PER_PAGE = 9;
			const filterButtons = Array.from(
				document.querySelectorAll<HTMLButtonElement>('.dx-cat[data-cat]')
			);
			const rows = Array.from(document.querySelectorAll<HTMLElement>('#insight-list > [data-category]'));
			const pagination = document.getElementById('pagination');
			let currentCat = 'all';
			let currentPage = 1;

			function render(scroll = false) {
				const visible = rows.filter(
					r => currentCat === 'all' || r.dataset.category === currentCat
				);
				const pages = Math.max(1, Math.ceil(visible.length / PER_PAGE));
				if (currentPage > pages) currentPage = pages;
				const start = (currentPage - 1) * PER_PAGE;
				const slice = visible.slice(start, start + PER_PAGE);
				rows.forEach(r => (r.style.display = slice.includes(r) ? '' : 'none'));
				// fresh stagger on every filter/page change; hidden rows lose .dxa-in
				// while display:none, so re-showing replays the entrance
				slice.forEach((r, i) => (r.style.transitionDelay = `${Math.min(i, 6) * 90}ms`));

				if (pagination) {
					pagination.innerHTML = '';
					if (pages > 1) {
						const mk = (label: string, page: number, opts: { active?: boolean; disabled?: boolean } = {}) => {
							const b = document.createElement('button');
							b.className = 'dx-page-btn' + (opts.active ? ' active' : '');
							b.textContent = label;
							b.disabled = !!opts.disabled;
							b.addEventListener('click', () => {
								currentPage = page;
								render(true);
							});
							pagination.appendChild(b);
						};
						mk('←', currentPage - 1, { disabled: currentPage === 1 });
						for (let p = 1; p <= pages; p++) mk(String(p), p, { active: p === currentPage });
						mk('→', currentPage + 1, { disabled: currentPage === pages });
					}
				}
				if (scroll)
					document.getElementById('insight-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}

			filterButtons.forEach(btn =>
				btn.addEventListener('click', () => {
					currentCat = btn.dataset.cat || 'all';
					currentPage = 1;
					filterButtons.forEach(b => b.classList.toggle('active', b === btn));
					render();
				})
			);

			render();
		</script>

		<DxMotion />
		<ChatWidget />
		<Analytics />
		<SpeedInsights />
	</body>
</html>
