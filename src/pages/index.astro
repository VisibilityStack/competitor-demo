---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';
import '../styles/fpt-dice.css';
import ChatWidget from '../components/ChatWidget.astro';
import DxMotion from '../components/DxMotion.astro';
import raycastIcon from '../assets/brands/raycast.svg?raw';
import railwayIcon from '../assets/brands/railway.svg?raw';
import resendIcon from '../assets/brands/resend.svg?raw';
import mintlifyIcon from '../assets/brands/mintlify.svg?raw';
import warpIcon from '../assets/brands/warp.svg?raw';
import zedIcon from '../assets/brands/zedindustries.svg?raw';

const partnerBrands = [
	{ name: 'Raycast', url: 'https://www.raycast.com', icon: raycastIcon },
	{ name: 'Railway', url: 'https://railway.com', icon: railwayIcon },
	{ name: 'Resend', url: 'https://resend.com', icon: resendIcon },
	{ name: 'Mintlify', url: 'https://mintlify.com', icon: mintlifyIcon },
	{ name: 'Warp', url: 'https://www.warp.dev', icon: warpIcon },
	{ name: 'Zed', url: 'https://zed.dev', icon: zedIcon },
];

const posts = (await getCollection('insights')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = posts[0];
const latest = posts.slice(1, 4);
const popular = posts.slice(0, 6);

const fmtDate = (d: Date) =>
	d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const categories = [
	{ emoji: '💼', label: 'Hiring playbooks' },
	{ emoji: '🧪', label: 'Hiring science' },
	{ emoji: '⚖️', label: 'Comparisons & alternatives' },
	{ emoji: '🤝', label: 'Choosing a partner' },
	{ emoji: '🎯', label: 'Leadership hiring' },
	{ emoji: '💵', label: 'Pricing & fees' },
];

const practices = [
	{ t: 'Product', s: 'PMs, Senior PMs, Founding PMs', slug: 'product' },
	{ t: 'Engineering', s: 'Full-stack, Backend, Frontend', slug: 'engineering' },
	{ t: 'Data & AI', s: 'Data scientists, ML engineers', slug: 'data-ai' },
	{ t: 'Leadership', s: 'CTOs, VPs, Heads of Data', slug: 'leadership' },
];

const minis = [
	{
		role: 'Staff Backend Engineer',
		meta: 'Series A logistics platform · NYC hybrid',
		comp: '$200–235k + equity',
		status: 'Interviewing now',
		hot: true,
	},
	{
		role: 'Founding Product Manager',
		meta: 'Seed devtools startup · Remote (US)',
		comp: '$170–200k + equity',
		status: 'Taking intros',
		hot: false,
	},
];

const reviews = [
	{
		text: 'I expected to be spammed with roles. Instead I heard nothing for five weeks, then one email about one company. That company is where I work now.',
		who: 'Staff Engineer, placed November 2025 · Series A infrastructure company',
		icon: 'code',
	},
	{
		text: "We'd been interviewing for four months with nothing to show for it. FPT sent three people in two weeks and honestly any of them could have done the job. The one we hired is still here a year later.",
		who: 'Founder & CEO · Seed-stage developer-tools startup',
		icon: 'case',
	},
	{
		text: 'They talked us out of a candidate we liked. That is when I started trusting them. The person we hired instead has been quietly excellent.',
		who: 'CTO · Healthcare software company',
		icon: 'cpu',
	},
];

const roleIcons: Record<string, string> = {
	code: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
	case: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
	cpu: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>',
};

const orgSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'FP Talent',
	alternateName: 'FPT',
	url: 'https://www.fptalent.io',
	logo: 'https://www.fptalent.io/favicon-fpt.svg',
	description:
		'The technical talent agency for software companies. End-to-end searches for product, engineering, data & AI, and leadership roles with psychometric screening included.',
	email: 'mark@fptalent.io',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'New York',
		addressRegion: 'NY',
		addressCountry: 'US',
	},
	contactPoint: {
		'@type': 'ContactPoint',
		contactType: 'sales',
		email: 'mark@fptalent.io',
	},
};
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>FP Talent</title>
		<meta
			name="description"
			content="The technical talent agency for founder-led software companies. Product, engineering, data & AI, and leadership hiring, done properly."
		/>
		<link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
		<link rel="icon" type="image/svg+xml" href="/favicon-fpt.svg?v=2" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
		/>
		<link rel="sitemap" href="/sitemap.xml" />
		<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
		<Analytics />
		<SpeedInsights />
	</head>
	<body>
		<a class="dx-skip" href="#main">Skip to content</a>
		<nav class="dx-nav">
			<div class="dx-container dx-nav-inner">
				<a class="dx-logo badge" href="/">FPT</a>
				<div class="dx-nav-links">
					<a href="/candidates#searches">Open searches</a>
					<a href="#practices">Practices</a>
					<a href="/insights">Insights</a>
					<a href="#why">Why FPT</a>
				</div>
				<details class="dx-nav-mob">
				<summary aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></summary>
				<div class="dx-nav-mob-panel">
						<a href="#practices">Practices</a>
						<a href="/insights">Insights</a>
						<a href="#why">Why FPT</a>
						<a href="/candidates">For candidates</a>
					</div>
			</details>
			<div class="dx-nav-right">
					<a class="dx-btn ghost" href="/candidates">For candidates</a>
					<a class="dx-btn teal" href="#contact">Book a consultation</a>
				</div>
			</div>
		</nav>

		<main id="main">
		<header class="dx-hero">
			<div class="dx-container dx-hero-grid">
				<div>
					<h1 data-dxa>Serious roles.<br /><span class="accent">Proper searches.</span></h1>
					<p class="dx-hero-sub" data-dxa>
						We run end-to-end searches for founder-led software companies, seed to
						Series B. Screened people, real comp, one company at a time.
					</p>
					<form class="dx-module" data-dxa method="get" action="/candidates">
						<p class="dx-module-title">Find your <span class="accent">next role</span></p>
						<div class="dx-module-row">
							<select name="practice" aria-label="Practice">
								<option value="">All practices</option>
								<option>Product</option>
								<option>Engineering</option>
								<option>Data &amp; AI</option>
								<option>Leadership</option>
							</select>
							<select name="stage" aria-label="Stage">
								<option value="">Any stage</option>
								<option>Seed</option>
								<option>Series A–B</option>
								<option>Later</option>
							</select>
							<button type="submit" class="dx-btn teal">See searches</button>
						</div>
					</form>
				</div>
				<div class="dx-collage">
					<div class="dx-bubble bb1">
						<div class="dx-avatar a1"><img src="/img/p-se.jpg" alt="Software engineer" /></div>
						<div class="dx-float f1"><span class="ic t1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></span>Match with screened talent</div>
					</div>
					<div class="dx-bubble bb2">
						<div class="dx-avatar a2"><img src="/img/p-pm.jpg" alt="Product manager" /></div>
						<div class="dx-float f2"><span class="ic t2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>Connect directly with founders</div>
					</div>
					<div class="dx-bubble bb3">
						<div class="dx-avatar a3"><img src="/img/p-ml.jpg" alt="ML engineer" /></div>
						<div class="dx-float f3"><span class="ic t3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span>First interview in 9 days</div>
					</div>
				</div>
			</div>
		</header>

		<div class="dx-strip">
			<div class="dx-container dx-strip-inner" data-dxa>
				<p>Hiring instead? We run the whole search.</p>
				<a class="dx-btn outline" href="#contact">Book a consultation</a>
			</div>
		</div>

		<section class="dx-logos">
			<div class="dx-container">
				<p class="dx-logos-label" data-dxa>Placements at teams like</p>
				<div class="dx-logos-row" data-dxa>
					{
						partnerBrands.map(b => (
							<a class="lockup" href={b.url} target="_blank" rel="noopener noreferrer" aria-label={`${b.name} website`}>
								<Fragment set:html={b.icon} />
								<span class="name">{b.name}</span>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-numbers" id="why">
			<div class="dx-container">
				<h2 data-dxa>FPT, by the numbers</h2>
				<div class="dx-tiles">
					<div class="dx-tile" data-dxa>
						<span class="v" data-count="29" data-prefix="−" data-suffix="%">−29%</span>
						<span class="c">time-to-hire on mid to senior roles</span>
					</div>
					<div class="dx-tile" data-dxa>
						<span class="v" data-count="82" data-suffix="%">82%</span>
						<span class="c">of placed candidates still in seat at 12 months</span>
					</div>
					<div class="dx-tile" data-dxa>
						<span class="v" data-count="9" data-suffix=" days">9 days</span>
						<span class="c">median from first call to first founder interview</span>
					</div>
				</div>
			</div>
		</section>

		<section class="dx-split">
			<div class="dx-container dx-split-grid">
				<div data-dxa>
					<p class="dx-kicker">For candidates</p>
					<h2>Find the right role, on your terms.</h2>
					<p class="lead">
						Every listing is funded, live, and interviewing, with comp published up
						front. Your profile goes nowhere without your OK, and the hiring
						company pays. Never you.
					</p>
					<div class="dx-cta-row">
						<a class="dx-btn teal" href="/candidates">See open searches</a>
						<a class="dx-btn outline" href="mailto:mark@fptalent.io?subject=Candidate%20intro">Send your profile</a>
					</div>
				</div>
				<div data-dxa>
					<div class="dx-photo">
						<img src="/img/team-candidates.jpg" alt="Engineers working around a table" loading="lazy" />
					</div>
					<div class="dx-minis dx-overlap">
						{
							minis.map((m, i) => (
								<div class="dx-mini-drop" data-dxa data-dxa-delay={`${250 + i * 300}ms`}>
									<span class="dx-mini-float" style={`animation-delay:${-i * 2.6}s`}>
										<a class="dx-search-card stacked" href="/candidates#searches">
											<span class="rolewrap">
												<span class="role">{m.role}</span>
												<span class="meta">{m.meta}</span>
											</span>
											<span class="comp">{m.comp}</span>
											<span class={`dx-pill ${m.hot ? 'hot' : 'cool'}`}>{m.status}</span>
										</a>
									</span>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="dx-resources">
			<div class="dx-container">
				<h2 data-dxa>Hiring insights, straight answers.</h2>
				<p class="sub" data-dxa>
					How searches actually run: screening, fees, timelines, and what good
					looks like at each stage.
				</p>
				<div class="dx-cats" data-dxa>
					{
						categories.map(c => (
							<a class="dx-cat" href="/insights">
								{c.emoji} {c.label}
							</a>
						))
					}
				</div>
				<div class="dx-res-grid">
					<div data-dxa>
						<a class="dx-feature" href={`/insights/${featured.slug}`}>
							<div>
								<p class="tag">{featured.data.category}</p>
								<p class="t">{featured.data.title}</p>
							</div>
							<span class="read">Read now →</span>
						</a>
					</div>
					{
						latest.map(p => (
							<div data-dxa>
								<a class="dx-article" href={`/insights/${p.slug}`}>
									<span class="cat">{p.data.category}</span>
									<span class="t">{p.data.title}</span>
									<span class="d">
										{fmtDate(p.data.date)} · {p.data.readingTime}
									</span>
								</a>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="dx-split" id="practices">
			<div class="dx-container">
				<div class="dx-split-grid">
					<div data-dxa>
						<p class="dx-kicker">For founders</p>
						<h2>Find and hire, properly.</h2>
						<p class="lead">
							One system, end to end: we co-write the JD, source directly, screen
							every candidate psychometrically, run panels with you, and close the
							offer. Success fee on placement, nothing before.
						</p>
						<div class="dx-cta-row">
							<a class="dx-btn teal" href="#contact">Book a consultation</a>
							<a class="dx-btn outline" href="/practices/engineering">See practices</a>
						</div>
					</div>
					<div data-dxa>
						<div class="dx-photo">
							<img src="/img/team-founders.jpg" alt="Founders celebrating a signed offer" loading="lazy" />
						</div>
						<div class="dx-practices dx-overlap">
							{
								practices.map(p => (
									<a class="dx-practice" href={`/practices/${p.slug}`}>
										<div class="t">{p.t}</div>
										<div class="s">{p.s}</div>
									</a>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="dx-quote-wrap">
			<div class="dx-container" data-dxa>
				<div class="dx-carousel" id="dx-carousel">
					<div class="dx-car-track" id="dx-car-track">
						{
							reviews.map(r => (
								<div class="dx-car-slide">
									<div class="dx-quote">
										<span class="dx-quote-icon" aria-hidden="true" set:html={roleIcons[r.icon]} />
										<blockquote>“{r.text}”</blockquote>
										<p class="who">{r.who}</p>
									</div>
								</div>
							))
						}
					</div>
					<div class="dx-dots" id="dx-dots">
						{
							reviews.map((_, i) => (
								<button class={i === 0 ? 'on' : ''} data-i={i} aria-label={`Review ${i + 1}`} />
							))
						}
					</div>
				</div>
			</div>
		</section>

		</main>

		<footer class="dx-footer" id="contact">
			<div class="dx-container">
				<div class="dx-footer-grid">
					<div>
						<h2>Let's build your team.</h2>
						<form id="dx-form" novalidate>
							<div class="dx-form-grid">
								<label class="sr-only" for="dx-f-first">First name</label>
								<input id="dx-f-first" type="text" name="firstName" placeholder="First name" autocomplete="given-name" required />
								<label class="sr-only" for="dx-f-last">Last name</label>
								<input id="dx-f-last" type="text" name="lastName" placeholder="Last name" autocomplete="family-name" required />
								<label class="sr-only" for="dx-f-email">Work email</label>
								<input id="dx-f-email" type="email" name="email" placeholder="Work email" autocomplete="email" required />
								<label class="sr-only" for="dx-f-company">Company</label>
								<input id="dx-f-company" type="text" name="company" placeholder="Company" autocomplete="organization" required />
							</div>
							<button type="submit" class="dx-btn teal">Book a consultation</button>
							<p class="dx-form-error" id="dx-form-error" role="alert"></p>
						</form>
						<p class="dx-thanks" id="dx-thanks" aria-live="polite"></p>
					</div>
					<div class="dx-foot-cols">
						<div>
							<h3>Practices</h3>
							<a href="/practices/product">Product</a>
							<a href="/practices/engineering">Engineering</a>
							<a href="/practices/data-ai">Data &amp; AI</a>
							<a href="/practices/leadership">Leadership</a>
						</div>
						<div>
							<h3>Company</h3>
							<a href="#why">Why FPT</a>
							<a href="/insights">Insights</a>
							<a href="mailto:mark@fptalent.io?subject=Hello%20FPT">Contact us</a>
						</div>
						<div>
							<h3>Candidates</h3>
							<a href="/candidates">Open searches</a>
							<a href="mailto:mark@fptalent.io?subject=Candidate%20intro">Send your profile</a>
						</div>
					</div>
				</div>
				<div class="dx-legal">
					<span>© 2026 FP Talent. All rights reserved.</span>
					<span>
						<a href="/terms">Terms</a>
						<a href="/privacy">Privacy policy</a>
					</span>
				</div>
			</div>
		</footer>

		<script>
			// consultation form -> same demo lead bucket as the rest of the site
			const form = document.getElementById('dx-form') as HTMLFormElement | null;
			const errEl = document.getElementById('dx-form-error');
			const thanks = document.getElementById('dx-thanks');
			form?.addEventListener('submit', e => {
				e.preventDefault();
				const data = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
				const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email || '');
				const labels: Record<string, string> = {
					firstName: 'first name',
					lastName: 'last name',
					email: 'work email',
					company: 'company',
				};
				const bad = [
					!data.firstName?.trim() && 'firstName',
					!data.lastName?.trim() && 'lastName',
					!emailOk && 'email',
					!data.company?.trim() && 'company',
				].filter(Boolean) as string[];
				form.querySelectorAll('input').forEach(i => {
					if (bad.includes(i.name)) i.setAttribute('aria-invalid', 'true');
					else i.removeAttribute('aria-invalid');
				});
				if (bad.length) {
					if (errEl)
						errEl.textContent =
							bad.length > 1
								? 'Please fill in every field and check the email address.'
								: `Please check the ${labels[bad[0]]} field.`;
					return;
				}
				if (errEl) errEl.textContent = '';
				try {
					const leads = JSON.parse(localStorage.getItem('fpt_demo_leads') || '[]');
					leads.push({ ...data, at: new Date().toISOString() });
					localStorage.setItem('fpt_demo_leads', JSON.stringify(leads));
				} catch {}
				form.hidden = true;
				if (thanks) thanks.textContent = 'Thank you. Talk soon.';
			});

		</script>

		<DxMotion />
		<ChatWidget />
	</body>
</html>
