---
// "Mark AI" — scripted concierge chatbot. Qualify (practice → stage) then
// capture an email, Dice-style 3-step flow. Leads land in the same
// localStorage bucket as the footer form. Styled for the dx (navy/teal) system.
---

<button class="fpt-chat-launch" id="fpt-chat-launch" aria-label="Chat with FPT">
	<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
		<path
			d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
			stroke-linecap="round"
			stroke-linejoin="round"></path>
	</svg>
</button>

<div class="fpt-chat-panel" id="fpt-chat-panel" hidden>
	<div class="fpt-chat-head">
		<div>
			<span class="fpt-chat-name">Mark AI</span>
			<span class="fpt-chat-sub">Talent partner</span>
		</div>
		<button class="fpt-chat-close" id="fpt-chat-close" aria-label="Close chat">×</button>
	</div>
	<div class="fpt-chat-body" id="fpt-chat-body" aria-live="polite"></div>
	<div class="fpt-chat-composer" id="fpt-chat-composer" hidden>
		<input
			type="email"
			id="fpt-chat-email"
			placeholder="Work email"
			autocomplete="email"
			aria-label="Work email"
		/>
		<button id="fpt-chat-send">Send</button>
	</div>
</div>

<style is:global>
	.fpt-chat-launch {
		position: fixed;
		right: 22px;
		bottom: 22px;
		width: 58px;
		height: 58px;
		border-radius: 50%;
		background: var(--dx-teal, #2ba3ae);
		color: #fff;
		border: 0;
		cursor: pointer;
		z-index: 70;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 12px 30px rgba(4, 14, 24, 0.35);
		transition: background 160ms ease, transform 160ms ease;
	}

	.fpt-chat-launch svg {
		width: 26px;
		height: 26px;
	}

	.fpt-chat-launch:hover {
		background: var(--dx-teal-dark, #21858f);
		transform: translateY(-2px);
	}

	.fpt-chat-panel[hidden],
	.fpt-chat-composer[hidden] {
		display: none !important;
	}

	.fpt-chat-panel {
		position: fixed;
		right: 22px;
		bottom: 92px;
		width: min(370px, calc(100vw - 32px));
		height: min(520px, 72vh);
		background: #fff;
		border-radius: 16px;
		overflow: hidden;
		z-index: 70;
		display: flex;
		flex-direction: column;
		font-family: var(--dx-font, 'IBM Plex Sans', -apple-system, sans-serif);
		box-shadow: 0 24px 64px rgba(4, 14, 24, 0.4);
	}

	.fpt-chat-head {
		background: var(--dx-navy, #0d2740);
		color: #fff;
		padding: 14px 16px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.fpt-chat-name {
		font-size: 17px;
		font-weight: 700;
		display: block;
		line-height: 1.2;
	}

	.fpt-chat-sub {
		display: block;
		font-size: 12.5px;
		color: rgba(255, 255, 255, 0.7);
	}

	.fpt-chat-close {
		background: transparent;
		border: 0;
		color: rgba(255, 255, 255, 0.85);
		font-size: 26px;
		line-height: 1;
		cursor: pointer;
		padding: 0 4px;
	}

	.fpt-chat-close:hover {
		color: #fff;
	}

	.fpt-chat-body {
		flex: 1;
		overflow-y: auto;
		padding: 16px 14px;
		display: flex;
		flex-direction: column;
		gap: 10px;
		background: #fff;
	}

	.fpt-chat-msg {
		max-width: 86%;
		padding: 10px 14px;
		font-size: 14.5px;
		line-height: 1.5;
		border-radius: 14px;
	}

	.fpt-chat-msg.bot {
		background: #f1f4f7;
		color: var(--dx-text, #1c2b39);
		align-self: flex-start;
		border-bottom-left-radius: 4px;
	}

	.fpt-chat-msg.user {
		background: var(--dx-navy, #0d2740);
		color: #fff;
		align-self: flex-end;
		border-bottom-right-radius: 4px;
	}

	.fpt-chat-typing {
		align-self: flex-start;
		padding: 12px 14px;
		background: #f1f4f7;
		border-radius: 14px;
		border-bottom-left-radius: 4px;
		display: inline-flex;
		gap: 5px;
	}

	.fpt-chat-typing .td {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--dx-teal, #2ba3ae);
		animation: fpt-tdots 1.1s ease-in-out infinite;
	}

	.fpt-chat-typing .td:nth-child(2) {
		animation-delay: 0.18s;
	}

	.fpt-chat-typing .td:nth-child(3) {
		animation-delay: 0.36s;
	}

	@keyframes fpt-tdots {
		0%,
		60%,
		100% {
			transform: translateY(0);
			opacity: 0.55;
		}
		30% {
			transform: translateY(-5px);
			opacity: 1;
		}
	}

	.fpt-chat-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-self: flex-start;
	}

	.fpt-chat-chip {
		font-family: inherit;
		font-size: 13.5px;
		font-weight: 600;
		background: #fff;
		border: 1.5px solid #d5dde4;
		color: var(--dx-text, #1c2b39);
		padding: 8px 14px;
		border-radius: 999px;
		cursor: pointer;
		transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
	}

	.fpt-chat-chip:hover {
		background: var(--dx-teal, #2ba3ae);
		border-color: var(--dx-teal, #2ba3ae);
		color: #fff;
	}

	.fpt-chat-composer {
		display: flex;
		gap: 8px;
		padding: 12px;
		border-top: 1px solid #e2e8ee;
		background: #fff;
	}

	.fpt-chat-composer input {
		flex: 1;
		border: 1.5px solid #d5dde4;
		border-radius: 10px;
		font-family: inherit;
		font-size: 16px;
		padding: 10px 12px;
		outline: none;
	}

	.fpt-chat-composer input:focus {
		border-color: var(--dx-teal, #2ba3ae);
	}

	.fpt-chat-composer button {
		font-family: inherit;
		font-size: 14.5px;
		font-weight: 600;
		background: var(--dx-teal, #2ba3ae);
		color: #fff;
		border: 0;
		border-radius: 10px;
		padding: 10px 18px;
		cursor: pointer;
		transition: background 140ms ease;
	}

	.fpt-chat-composer button:hover {
		background: var(--dx-teal-dark, #21858f);
	}

	@media (max-width: 640px) {
		.fpt-chat-panel {
			right: 16px;
			bottom: 88px;
		}
	}
</style>

<script>
	const launch = document.getElementById('fpt-chat-launch');
	const panel = document.getElementById('fpt-chat-panel');
	const body = document.getElementById('fpt-chat-body');
	const closeBtn = document.getElementById('fpt-chat-close');
	const composer = document.getElementById('fpt-chat-composer');
	const emailInput = document.getElementById('fpt-chat-email') as HTMLInputElement | null;
	const sendBtn = document.getElementById('fpt-chat-send');

	let started = false;
	const lead: Record<string, string> = {};

	const scroll = () => {
		if (body) body.scrollTop = body.scrollHeight;
	};

	function addMsg(who: 'bot' | 'user', text: string) {
		const el = document.createElement('div');
		el.className = `fpt-chat-msg ${who}`;
		el.textContent = text;
		body?.appendChild(el);
		scroll();
	}

	function botSay(text: string, after?: () => void) {
		const typing = document.createElement('div');
		typing.className = 'fpt-chat-typing';
		typing.innerHTML = '<span class="td"></span><span class="td"></span><span class="td"></span>';
		body?.appendChild(typing);
		scroll();
		setTimeout(() => {
			typing.remove();
			addMsg('bot', text);
			if (after) after();
		}, 700);
	}

	function addChips(chips: { label: string; onPick: () => void }[]) {
		const wrap = document.createElement('div');
		wrap.className = 'fpt-chat-chips';
		chips.forEach(chip => {
			const b = document.createElement('button');
			b.className = 'fpt-chat-chip';
			b.textContent = chip.label;
			b.addEventListener('click', () => {
				wrap.remove();
				addMsg('user', chip.label);
				chip.onPick();
			});
			wrap.appendChild(b);
		});
		body?.appendChild(wrap);
		scroll();
	}

	function askEmail() {
		if (lead.email) {
			botSay('Already got your email. Mark will be in touch.');
			return;
		}
		botSay('Fastest next step is a short consultation. Where should we reach you?', () => {
			if (composer) composer.hidden = false;
			emailInput?.focus();
		});
	}

	function saveLead() {
		try {
			const leads = JSON.parse(localStorage.getItem('fpt_demo_leads') || '[]');
			leads.push({ ...lead, source: 'chat', at: new Date().toISOString() });
			localStorage.setItem('fpt_demo_leads', JSON.stringify(leads));
		} catch {}
	}

	function askStage() {
		botSay('What stage are you at?', () =>
			addChips([
				{ label: 'Pre-seed / Seed', onPick: () => stagePicked('Pre-seed / Seed') },
				{ label: 'Series A–B', onPick: () => stagePicked('Series A–B') },
				{ label: 'Later stage', onPick: () => stagePicked('Later stage') },
			])
		);
	}

	function stagePicked(stage: string) {
		lead.stage = stage;
		askEmail();
	}

	function practicePicked(practice: string) {
		lead.practice = practice;
		askStage();
	}

	function start() {
		botSay('Mark AI here, from FPT. What are you hiring for?', () =>
			addChips([
				{ label: 'Product', onPick: () => practicePicked('Product') },
				{ label: 'Engineering', onPick: () => practicePicked('Engineering') },
				{ label: 'Data & AI', onPick: () => practicePicked('Data & AI') },
				{ label: 'Leadership', onPick: () => practicePicked('Leadership') },
				{ label: 'Just looking', onPick: browsing },
			])
		);
	}

	function browsing() {
		botSay('All good. The Insights hub is the best place to poke around.', () =>
			addChips([
				{ label: 'Read Insights', onPick: () => (window.location.href = '/insights') },
				{ label: "I'm a candidate", onPick: () => (window.location.href = '/candidates') },
				{ label: 'How you work', onPick: how },
				{ label: "What's it cost", onPick: pricing },
			])
		);
	}

	const asked = new Set();

	function followUps() {
		const chips = [];
		if (!asked.has('how')) chips.push({ label: 'How you work', onPick: how });
		if (!asked.has('cost')) chips.push({ label: "What's it cost", onPick: pricing });
		if (!lead.email) chips.push({ label: 'Book a consultation', onPick: askEmail });
		chips.push({ label: "That's all", onPick: () => botSay('Talk soon.') });
		addChips(chips);
	}

	function pricing() {
		asked.add('cost');
		botSay('Simple. A fee when we place someone. No retainers, no add-ons.', followUps);
	}

	function how() {
		asked.add('how');
		botSay('The whole search, end to end. We find the people, screen them, and stay on it until the offer is signed.', followUps);
	}

	let emailNagged = false;
	function submitEmail() {
		const val = emailInput?.value.trim() || '';
		if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
			if (!emailNagged) {
				emailNagged = true;
				botSay("That email doesn't look right. Mind checking it?");
			}
			emailInput?.focus();
			return;
		}
		lead.email = val;
		addMsg('user', val);
		if (composer) composer.hidden = true;
		saveLead();
		botSay('Got it, thanks. Mark will be in touch.', followUps);
	}

	launch?.addEventListener('click', () => {
		if (panel) panel.hidden = !panel.hidden;
		if (!panel?.hidden && !started) {
			started = true;
			start();
		}
	});
	closeBtn?.addEventListener('click', () => {
		if (panel) panel.hidden = true;
	});
	document.addEventListener('keydown', e => {
		if (e.key === 'Escape' && panel && !panel.hidden) panel.hidden = true;
	});
	sendBtn?.addEventListener('click', submitEmail);
	emailInput?.addEventListener('keydown', e => {
		if (e.key === 'Enter') submitEmail();
	});
</script>
