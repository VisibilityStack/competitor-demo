---
// Scroll-reveal, count-up, match-ping, and nav-stuck driver for dx pages.
---

<script>
	const noMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

	const els = Array.from(document.querySelectorAll<HTMLElement>('[data-dxa]'));
	els.forEach(el => {
		const parent = el.parentElement;
		if (!parent) return;
		// data-dxa-delay opts an element out of sibling stagger with its own delay
		if (el.dataset.dxaDelay) {
			el.style.transitionDelay = el.dataset.dxaDelay;
			return;
		}
		const sibs = Array.from(parent.children).filter(c => c.hasAttribute('data-dxa'));
		const i = sibs.indexOf(el);
		if (i > 0) el.style.transitionDelay = `${Math.min(i, 6) * 90}ms`;
	});
	// reveals replay on every entrance: add in view, reset once fully out
	const io = new IntersectionObserver(
		entries =>
			entries.forEach(e => {
				if (e.isIntersecting) {
					e.target.classList.add('dxa-in');
				} else {
					e.target.classList.remove('dxa-in');
				}
			}),
		{ threshold: 0.15, rootMargin: '0px 0px -14% 0px' }
	);
	els.forEach(el => io.observe(el));

	// count-up: fires once per full entrance, resets silently only when fully
	// off-screen (IntersectionObserver reports both threshold crossings and
	// isIntersecting flips, so guard against 1px-entry and mid-view re-fires)
	if (!noMotion) {
		const rafs = new WeakMap<Element, number>();
		const started = new WeakSet<Element>();
		const cio = new IntersectionObserver(
			entries =>
				entries.forEach(e => {
					const el = e.target as HTMLElement;
					const pre = el.dataset.prefix || '';
					const suf = el.dataset.suffix || '';
					const target = Number(el.dataset.count || 0);
					if (!e.isIntersecting) {
						if (started.has(el)) {
							started.delete(el);
							const r = rafs.get(el);
							if (r) cancelAnimationFrame(r);
							el.textContent = pre + '0' + suf;
							el.closest('.dx-tiles')
								?.querySelector('.v:not([data-count])')
								?.classList.remove('dx-zero-pop');
						}
						return;
					}
					if (e.intersectionRatio < 0.4 || started.has(el)) return;
					started.add(el);
					const start = performance.now();
					const dur = 1500;
					const tick = (now: number) => {
						const p = Math.min(1, (now - start) / dur);
						const eased = 1 - Math.pow(1 - p, 3);
						el.textContent = pre + Math.round(target * eased) + suf;
						if (p < 1) {
							rafs.set(el, requestAnimationFrame(tick));
						} else {
							// the static "$0" tile lands as the punchline
							el.closest('.dx-tiles')
								?.querySelector('.v:not([data-count])')
								?.classList.add('dx-zero-pop');
						}
					};
					rafs.set(el, requestAnimationFrame(tick));
				}),
			{ threshold: [0, 0.4] }
		);
		document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));
	}

	// match ping: one avatar at a time emits a live ring
	const avatars = Array.from(
		document.querySelectorAll('.dx-collage .dx-avatar, .dxc-collage .dx-avatar')
	);
	if (avatars.length && !noMotion) {
		let p = 0;
		setInterval(() => {
			if (document.hidden) return;
			const el = avatars[p % avatars.length];
			p++;
			el.classList.add('ping');
			setTimeout(() => el.classList.remove('ping'), 1700);
		}, 4200);
	}

	// reviews carousel (any page with #dx-car-track): auto-advance + dots,
	// paused on hover/focus, in hidden tabs, and for reduced motion
	const track = document.getElementById('dx-car-track');
	const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#dx-dots button'));
	if (track && dots.length) {
		let slide = 0;
		let timer = 0;
		const show = (i: number) => {
			slide = (i + dots.length) % dots.length;
			track.style.transform = `translateX(-${slide * 100}%)`;
			dots.forEach((d, j) => d.classList.toggle('on', j === slide));
		};
		const stop = () => clearInterval(timer);
		const play = () => {
			stop();
			if (!noMotion && !document.hidden) timer = window.setInterval(() => show(slide + 1), 5500);
		};
		play();
		document.addEventListener('visibilitychange', play);
		const box = track.closest('.dx-carousel');
		box?.addEventListener('pointerenter', stop);
		box?.addEventListener('pointerleave', play);
		box?.addEventListener('focusin', stop);
		box?.addEventListener('focusout', play);
		dots.forEach(d =>
			d.addEventListener('click', () => {
				show(Number(d.dataset.i));
				play();
			})
		);
	}

	// mobile menu: close on link tap, outside tap, or Escape
	const mobs = Array.from(document.querySelectorAll<HTMLElement>('.dx-nav-mob'));
	mobs.forEach(d => {
		d.querySelectorAll('a').forEach(a => a.addEventListener('click', () => d.removeAttribute('open')));
	});
	document.addEventListener('click', e => {
		mobs.forEach(d => {
			if (d.hasAttribute('open') && !d.contains(e.target as Node)) d.removeAttribute('open');
		});
	});
	document.addEventListener('keydown', e => {
		if (e.key === 'Escape') mobs.forEach(d => d.removeAttribute('open'));
	});

	// layout mode (?layout): drag hero elements to place them, positions shown
	// and saved to localStorage so the final spots can be read and hard-coded.
	// Toasts save top/right % of the hero, bubbles top/left % of the collage,
	// chips top/left px within their own bubble.
	if (new URLSearchParams(location.search).has('layout')) {
		document.body.classList.add('dx-layout');
		const tag = document.createElement('div');
		tag.className = 'dx-pos-tag';
		tag.textContent = 'Layout mode: drag a notification, photo, or chip to place it';
		document.body.appendChild(tag);

		type Pos = Record<string, Record<string, string>>;
		const toastKey = 'fpt_toast_pos';
		const heroKey = 'fpt_hero_pos_' + location.pathname;
		const toastStore: Pos = JSON.parse(localStorage.getItem(toastKey) || '{}');
		const heroStore: Pos = JSON.parse(localStorage.getItem(heroKey) || '{}');

		// older saves stored bare numbers meaning %
		const unit = (s: string) => (/(%|px)$/.test(s) ? s : s + '%');
		const applyPos = (el: HTMLElement, v: Record<string, string>) => {
			el.style.top = unit(v.top);
			if (v.right) {
				el.style.right = unit(v.right);
				el.style.left = 'auto';
			} else {
				el.style.left = unit(v.left);
				el.style.right = 'auto';
			}
			el.style.bottom = 'auto';
		};

		Object.entries(toastStore).forEach(([k, v]) => {
			const el = document.querySelector<HTMLElement>('.dx-toast.' + k);
			if (el) applyPos(el, v);
		});
		Object.entries(heroStore).forEach(([k, v]) => {
			const el = document.querySelector<HTMLElement>('.dx-bubble.' + k + ', .dx-float.' + k);
			if (el) applyPos(el, v);
		});

		const wire = (el: HTMLElement, mode: 'toast' | 'pct' | 'px', store: Pos, storeName: string) => {
			let active = false;
			let moved = false;
			let sx = 0, sy = 0, ox = 0, oy = 0, bw = 0, bh = 0;
			el.addEventListener('pointerdown', e => {
				e.stopPropagation();
				e.preventDefault();
				const box = el.parentElement as HTMLElement;
				const r = el.getBoundingClientRect();
				const br = box.getBoundingClientRect();
				sx = e.clientX;
				sy = e.clientY;
				ox = r.left - br.left;
				oy = r.top - br.top;
				bw = br.width;
				bh = br.height;
				moved = false;
				active = true;
				el.setPointerCapture(e.pointerId);
			});
			el.addEventListener('pointermove', ev => {
				// only a held-down drag on this element may move it
				if (!active || ev.buttons === 0) return;
				const nx = ox + ev.clientX - sx;
				const ny = oy + ev.clientY - sy;
				if (Math.abs(ev.clientX - sx) + Math.abs(ev.clientY - sy) > 6) moved = true;
				el.style.animation = 'none';
				const key = el.classList[1];
				let v: Record<string, string>;
				if (mode === 'toast') {
					v = {
						top: ((ny / bh) * 100).toFixed(1) + '%',
						right: (((bw - nx - el.offsetWidth) / bw) * 100).toFixed(1) + '%',
					};
				} else if (mode === 'pct') {
					v = {
						top: ((ny / bh) * 100).toFixed(1) + '%',
						left: ((nx / bw) * 100).toFixed(1) + '%',
					};
				} else {
					v = { top: Math.round(ny) + 'px', left: Math.round(nx) + 'px' };
				}
				applyPos(el, v);
				store[key] = v;
				localStorage.setItem(storeName, JSON.stringify(store));
				tag.textContent = `${key} → top ${v.top} · ${v.right ? 'right ' + v.right : 'left ' + v.left}`;
			});
			const end = () => {
				active = false;
			};
			el.addEventListener('pointerup', end);
			el.addEventListener('pointercancel', end);
			// a real drag must not fire the element's click actions (toast dismiss)
			el.addEventListener(
				'click',
				e => {
					if (moved) {
						e.stopImmediatePropagation();
						moved = false;
					}
				},
				true
			);
		};

		document.querySelectorAll<HTMLElement>('.dx-toast').forEach(t => wire(t, 'toast', toastStore, toastKey));
		document.querySelectorAll<HTMLElement>('.dx-bubble').forEach(b => wire(b, 'pct', heroStore, heroKey));
		document.querySelectorAll<HTMLElement>('.dx-bubble .dx-float').forEach(c => wire(c, 'px', heroStore, heroKey));
	}

	// notification toasts dismiss on click or keyboard
	document.querySelectorAll<HTMLElement>('.dx-toast').forEach(t => {
		const dismiss = () => {
			t.classList.add('out');
			setTimeout(() => t.remove(), 400);
		};
		t.addEventListener('click', dismiss);
		t.addEventListener('keydown', e => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				dismiss();
			}
		});
	});

	// sticky nav: soft shadow once the page scrolls under it
	const nav = document.querySelector('.dx-nav');
	if (nav) {
		const sentinel = document.createElement('div');
		sentinel.style.cssText = 'position:absolute;top:0;width:1px;height:1px;';
		document.body.prepend(sentinel);
		new IntersectionObserver(([e]) =>
			nav.classList.toggle('stuck', !e.isIntersecting)
		).observe(sentinel);
	}
</script>
